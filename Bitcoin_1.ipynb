    "from neuralforecast import NeuralForecast\n",
    "from neuralforecast.models import TFT"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "izZcmJ7YNDcP",
   "metadata": {
    "id": "izZcmJ7YNDcP"
   },
   "source": [
    "1. Log Returns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "VmBge2XXG0qk",
   "metadata": {
    "id": "VmBge2XXG0qk"
   },
   "outputs": [],
   "source": [
    "tft_df = A_model.copy().reset_index()  # brings Open time back as column\n",
    "tft_df = tft_df.rename(columns={'Open time': 'ds', 'target': 'y'})\n",
    "tft_df['unique_id'] = 'BTC'\n",
    "\n",
    "n = len(tft_df)\n",
    "train_end = int(n * 0.7)\n",
    "val_end   = int(n * 0.85)\n",
    "\n",
    "tft_train = tft_df.iloc[:train_end]\n",
    "tft_val   = tft_df.iloc[train_end:val_end]\n",
    "tft_test  = tft_df.iloc[val_end:]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
