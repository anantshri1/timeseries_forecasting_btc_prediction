   "outputs": [],
   "source": [
    "feature_cols = [\n",
    "    'log_return', 'realised_vol_24h', 'realised_vol_168h',\n",
    "    'candle_body', 'upper_wick', 'lower_wick', 'hl_range',\n",
    "    'taker_ratio', 'volume_ma_ratio', 'rsi',\n",
