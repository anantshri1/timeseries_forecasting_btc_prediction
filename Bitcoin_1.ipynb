   "source": [
    "2. 24h Volatility, but with hyperparameter tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e7-dsyq4MsFh",
   "metadata": {
    "id": "e7-dsyq4MsFh"
   },
   "outputs": [],
   "source": [
    "tft_df_b = B_model.copy().reset_index()  # brings Open time back as column\n",
    "tft_df_b = tft_df_b.rename(columns={'Open time': 'ds', 'target': 'y'})\n",
    "tft_df_b['unique_id'] = 'BTC'\n",
    "\n",
    "# Temporal split — same proportions as before\n",
    "n_b = len(tft_df_b)\n",
    "train_end_b = int(n_b * 0.7)\n",
    "val_end_b   = int(n_b * 0.85)\n",
    "\n",
    "tft_train_b = tft_df_b.iloc[:train_end_b]\n",
    "tft_val_b   = tft_df_b.iloc[train_end_b:val_end_b]\n",
    "tft_test_b  = tft_df_b.iloc[val_end_b:]"
   ]
  },
